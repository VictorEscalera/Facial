# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
UserInterfaceState.xcuserstate
$RECYCLE.BIN/

*.log
log.txt
*.hprof


/.sourcemaps
/.versions
/coverage

# Ionic
/.ionic
/www
/platforms
/plugins

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Node
**/node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment and secrets
.env
.env.*
!.env.example
!.env.*.example
*.local

# Local biometric reference images
/src/assets/images/yo.jpeg
/src/assets/images/Sergio.jpeg

# Local SDK configuration and signing credentials
local.properties
*.jks
*.keystore
*.p12
*.pfx
key.properties
keystore.properties

# Gradle and native build caches
**/.gradle/
**/.kotlin/
**/.cxx/

# Arduino and PlatformIO generated files
.arduinoIDE/
.pio/
arduino_build_*/
arduino_cache_*/
*.hex
*.elf
*.eep

# Python environments and caches
.venv/
venv/
__pycache__/
*.py[cod]

# Runtime process files
*.pid
*.pid.lock

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-project
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Local AI/editor metadata
/.agents/
/.codex/


# Miscellaneous
/.angular
/.angular/cache
.sass-cache/
/.nx
/.nx/cache
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings

# System files
.DS_Store
Thumbs.db
